{
  "$comment": "Schema: schemas/model-routing.schema.json (to be created)",
  "version": 2,
  "description": "Model routing configuration — maps task types to models with Anthropic, OpenRouter, and local Ollama support",
  "providers": {
    "anthropic": {
      "enabled": true,
      "priority": 1,
      "models": {
        "opus": "claude-opus-4-6",
        "sonnet": "claude-sonnet-4-6",
        "haiku": "claude-haiku-4-5"
      }
    },
    "openrouter": {
      "enabled": true,
      "priority": 2,
      "api_base": "https://openrouter.ai/api/v1",
      "models": {
        "code": "qwen/qwen3-coder",
        "code-fallback": "meta-llama/llama-4-maverick",
        "analysis": "google/gemini-2.5-pro",
        "general": "deepseek/deepseek-chat-v3-0324",
        "code-free": "qwen/qwen3-coder:free",
        "embedding": "openai/text-embedding-3-small",
        "voice": "openai/whisper-1"
      },
      "env_key": "OPENROUTER_API_KEY",
      "env_file": "~/.claude/.env.local",
      "benchmarks": {
        "reference": "docs/local-models/openrouter-benchmarks.md",
        "date": "2026-03-26",
        "winner": "qwen/qwen3-coder",
        "scores": {
          "qwen/qwen3-coder": { "correctness": 9.5, "speed_avg_s": 2.1, "quality": 9.3 },
          "meta-llama/llama-4-maverick": { "correctness": 9.2, "speed_avg_s": 2.9, "quality": 8.8 },
          "deepseek/deepseek-chat-v3-0324": { "correctness": 9.0, "speed_avg_s": 3.9, "quality": 8.3 },
          "google/gemini-2.5-pro": { "correctness": 8.7, "speed_avg_s": 34.8, "quality": 8.8 }
        }
      }
    },
    "ollama": {
      "enabled": true,
      "priority": 3,
      "base_url": "http://localhost:11434",
      "health_check": "http://localhost:11434/api/tags",
      "models": {
        "small": "llama3.2:3b",
        "code": "qwen2.5-coder:7b"
      },
      "installed": ["llama3.2:3b", "qwen2.5-coder:7b"],
      "pull_on_first_use": true,
      "gpu_layers": 0,
      "context_length": 32768,
      "benchmarks": {
        "llama3.2:3b": {"tok_per_sec_cpu": 12, "ram_gb": 2.5, "quality": "adequate"},
        "qwen2.5-coder:7b": {"tok_per_sec_cpu": 5, "ram_gb": 5.5, "quality": "good"}
      }
    }
  },
  "routing": {
    "planning": {
      "primary": "anthropic:opus",
      "fallback": "openrouter:analysis",
      "local_fallback": "ollama:large",
      "description": "Architecture, design, and strategic planning"
    },
    "implementation": {
      "primary": "anthropic:sonnet",
      "fallback": "openrouter:code",
      "local_fallback": "ollama:code",
      "description": "Code generation and editing"
    },
    "review": {
      "primary": "anthropic:sonnet",
      "fallback": "ollama:large",
      "description": "Code review and security audit"
    },
    "testing": {
      "primary": "anthropic:sonnet",
      "fallback": "ollama:medium",
      "description": "Test generation and debugging"
    },
    "triage": {
      "primary": "anthropic:haiku",
      "fallback": "ollama:small",
      "description": "Quick classification, routing, status checks"
    },
    "embedding": {
      "primary": "anthropic:haiku",
      "fallback": "ollama:embed",
      "description": "RAG embedding and similarity search"
    }
  },
  "fallback_policy": {
    "trigger": "api_error_or_budget_exceeded",
    "conditions": [
      "HTTP 429 (rate limit)",
      "HTTP 529 (overloaded)",
      "HTTP 500+ (server error)",
      "Budget remaining < $1",
      "Network timeout > 30s"
    ],
    "chain": "anthropic → openrouter → ollama (if enabled)",
    "behavior": "If primary provider returns an error matching any condition, try next provider in chain. Log fallback events to telemetry."
  },
  "offline_mode": {
    "enabled": false,
    "description": "When true, skip Anthropic entirely and use only Ollama models. Useful for air-gapped environments or cost-zero development.",
    "activate_command": "Set CLAUDE_OFFLINE=1 in environment or pass --offline to ghost/auto-dev"
  },
  "specialized": {
    "voice": {
      "primary": "scripts/transcribe-voice.sh",
      "notes": "Gemini free primary, Whisper fallback — handled internally by script"
    },
    "image": {
      "primary": "gemini-mcp:imagen3",
      "notes": "Via @rlabs-inc/gemini-mcp, requires setup-gemini-mcp.sh"
    },
    "embedding": {
      "primary": "openrouter:embedding",
      "fallback": "ollama:nomic-embed-text"
    }
  },
  "dual_mode": {
    "enabled": false,
    "default_models": ["openrouter:code", "openrouter:general"],
    "judge": "anthropic:opus",
    "log_file": "~/.claude/logs/comparisons.jsonl"
  },
  "cost_tracking": {
    "log_file": "~/.claude/logs/model-costs.jsonl",
    "warn_at_usd": 40,
    "hard_limit_usd": 50
  }
}
