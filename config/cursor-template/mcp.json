{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sandbox": {
      "command": "uv",
      "args": [
        "run", "--with", "mcp[cli]", "--with", "pydantic",
        "python3", "${userHome}/.claude/mcp-servers/sandbox-server.py"
      ]
    },
    "learning": {
      "command": "uv",
      "args": [
        "run", "--with", "mcp[cli]",
        "python3", "${userHome}/.claude/mcp-servers/learning-server.py"
      ]
    }
  }
}
