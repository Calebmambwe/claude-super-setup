      "model_tier": "opus",
      "capabilities": ["openapi-design", "rest-api", "api-versioning", "authentication-schemes", "schema-design"],
      "tools": ["Read", "Write", "Grep", "Glob"],
      "teams": ["backend", "fullstack", "review"]
