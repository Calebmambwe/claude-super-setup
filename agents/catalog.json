{
  "$schema": "../schemas/catalog.schema.json",
  "version": "1.0.0",
  "model_tiers": {
    "haiku": {
      "model": "claude-haiku-3-5",
      "use_for": "Fast, lightweight tasks: content generation, simple queries, high-volume repetitive work"
    },
    "sonnet": {
      "model": "claude-sonnet-4-6",
      "use_for": "General engineering and analysis tasks: coding, debugging, research, standard reviews"
    },
    "opus": {
      "model": "claude-opus-4",
      "use_for": "Complex reasoning tasks: architecture decisions, security audits, legal review, ML design"
    },
    "custom": {
      "model": "user-defined",
      "use_for": "Agents that override the model per-invocation or use a fine-tuned model"
    }
  },
  "teams": {
    "review": {
      "description": "Code quality, security, and documentation review pipeline",
      "agents": ["code-reviewer", "security-auditor", "doc-verifier", "tdd-test-writer", "verifier"]
    },
    "frontend": {
      "description": "Frontend and UI development team",
      "agents": ["frontend-dev", "frontend-developer", "ui-designer", "ux-researcher", "visual-tester", "whimsy-injector"]
    },
    "backend": {
      "description": "Backend and API development team",
      "agents": ["backend-dev", "backend-architect", "api-architect", "security-auditor", "tdd-test-writer", "verifier"]
    },
    "fullstack": {
      "description": "Full-stack feature development team",
      "agents": ["architect", "backend-dev", "frontend-dev", "api-architect", "tdd-test-writer", "code-reviewer", "security-auditor", "verifier"]
    },
    "mobile": {
      "description": "Mobile application development team",
      "agents": ["mobile-app-builder", "rn-accessibility", "rn-performance", "rn-security", "visual-tester"]
    },
    "research": {
      "description": "Technical research and trend analysis team",
      "agents": ["researcher", "trend-researcher", "doc-verifier", "prompt-engineer"]
    },
    "security": {
      "description": "Security review and compliance team",
      "agents": ["security-auditor", "legal-compliance-checker", "rn-security", "code-reviewer"]
    }
  },
  "agents": [
    {
      "name": "api-architect",
