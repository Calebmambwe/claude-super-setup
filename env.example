# Claude Super Setup — Environment Variables
# Copy this file to .env: cp env.example .env
# Then fill in your API key.

# Required for autonomous CI/CD (improve.yml weekly proposals)
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# Optional: Override subagent model (default: claude-sonnet-4-6)
# CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-4-6

# Optional: Enable telemetry
# CLAUDE_CODE_ENABLE_TELEMETRY=1
